    <table cellpadding="0" cellspacing="0" border="0" width="100%" class="grid" style="margin: 0;">
                <tr id="comment-header-382423"><td bgcolor="#f0f0f0">
            评论于 
                                                        <a class="user-hover" rel="zfwang" id="word_commented_zfwang" href="https://jira.51tyty.com/secure/ViewProfile.jspa?name=zfwang">王之枫</a>
                                        <font size="-2">
            [
                <font color="#336699">12/&#19977;&#26376;/26</font>

                            ]
            </font>

        </td></tr>
        <tr id="comment-body-382423"><td bgcolor="#ffffff">
            SELECT<br/>
&nbsp;&nbsp;`A88_T_1_`.`user_id` AS T_A45_4_,<br/>
&nbsp;&nbsp;`A88_T_1_`.`nickname` AS T_AF1_5_,<br/>
&nbsp;&nbsp;`A88_T_1_`.`username` AS T_A59_6_,<br/>
&nbsp;&nbsp;`A58_T_3_`.`所在班级` AS T_A05_7_,<br/>
&nbsp;&nbsp;SUM(`A98_T_2_`.`serial_com_task_count`) AS T_A5A_8_,<br/>
&nbsp;&nbsp;SUM(`A98_T_2_`.`serial_total_task_count`) AS T_A50_9_,<br/>
&nbsp;&nbsp;SUM(`A98_T_2_`.`days_completed`) AS T_A67_10_,<br/>
&nbsp;&nbsp;SUM(A98_T_2_.`serial_com_task_count`) / SUM(A98_T_2_.`serial_total_task_count`) AS T_AA4_11_,<br/>
&nbsp;&nbsp;SUM(`A98_T_2_`.`signed_days`) AS T_A0D_12_,<br/>
&nbsp;&nbsp;SUM(`A98_T_2_`.`unsigned_days`) AS T_A2E_13_,<br/>
&nbsp;&nbsp;SUM(A98_T_2_.`signed_days`) /(<br/>
&nbsp;&nbsp;&nbsp;&nbsp;SUM(A98_T_2_.`signed_days`) + SUM(A98_T_2_.`unsigned_days`)<br/>
&nbsp;&nbsp;) AS T_AC6_14_,<br/>
&nbsp;&nbsp;SUM(A98_T_2_.`serial_score_sum`) / SUM(A98_T_2_.`serial_com_hasscore_task_count`) AS T_A10_15_<br/>
FROM<br/>
&nbsp;&nbsp;(<br/>
&nbsp;&nbsp;&nbsp;&nbsp;select<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;`inst_id`,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;`user_id`,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;`username`,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ifNUll(nickname_note, `nickname`) as nickname,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;mobile<br/>
&nbsp;&nbsp;&nbsp;&nbsp;from<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;`dcp_inst_user_info`<br/>
&nbsp;&nbsp;&nbsp;&nbsp;WHERE<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;`inst_id` = &#39;53754&#39;<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;and `role_id` = 6<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;and `user_status` != 3<br/>
&nbsp;&nbsp;&nbsp;&nbsp;ORDER BY<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;user_id asc<br/>
&nbsp;&nbsp;) AS A88_T_1_<br/>
&nbsp;&nbsp;LEFT JOIN (<br/>
&nbsp;&nbsp;&nbsp;&nbsp;SELECT<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;pub_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;com_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;serial_total_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;serial_com_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;signed_days,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;serial_score_sum,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;serial_com_hasscore_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;unsigned_days,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;IF (<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;serial_total_task_count != 0<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;and serial_total_task_count = serial_com_task_count,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;1,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;) as days_completed,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;count_date,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;inst_id,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;user_id<br/>
&nbsp;&nbsp;&nbsp;&nbsp;FROM<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;dcp_user_task_count<br/>
&nbsp;&nbsp;&nbsp;&nbsp;WHERE<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;inst_id = &#39;53754&#39;<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;AND count_date &gt;= &#39;2024-11-11&#39;<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;AND count_date &lt;= &#39;2025-11-16&#39;<br/>
&nbsp;&nbsp;) AS A98_T_2_ ON `A88_T_1_`.`user_id` = `A98_T_2_`.`user_id`<br/>
&nbsp;&nbsp;LEFT JOIN (<br/>
&nbsp;&nbsp;&nbsp;&nbsp;SELECT<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;user_id,<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;group_concat(DISTINCT(`group_name`)) as 所在班级<br/>
&nbsp;&nbsp;&nbsp;&nbsp;FROM<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;dcp_student_class_relation<br/>
&nbsp;&nbsp;&nbsp;&nbsp;WHERE<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;inst_id = &#39;53754&#39;<br/>
&nbsp;&nbsp;&nbsp;&nbsp;GROUP BY<br/>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;user_id<br/>
&nbsp;&nbsp;) AS A58_T_3_ ON `A88_T_1_`.`user_id` = `A58_T_3_`.`user_id`<br/>
WHERE<br/>
&nbsp;&nbsp;`A88_T_1_`.`mobile` LIKE &#39;%18752004616%&#39;<br/>
GROUP BY<br/>
&nbsp;&nbsp;`A88_T_1_`.`user_id`,<br/>
&nbsp;&nbsp;`A88_T_1_`.`nickname`,<br/>
&nbsp;&nbsp;`A88_T_1_`.`username`,<br/>
&nbsp;&nbsp;`A58_T_3_`.`所在班级`<br/>
ORDER BY<br/>
&nbsp;&nbsp;T_AA4_11_ DESC,<br/>
&nbsp;&nbsp;T_A45_4_ ASC<br/>
LIMIT<br/>
&nbsp;&nbsp;0, 20
        </td></tr>
                <tr id="comment-header-382424"><td bgcolor="#f0f0f0">
            评论于 
                                                        <a class="user-hover" rel="zfwang" id="word_commented_zfwang" href="https://jira.51tyty.com/secure/ViewProfile.jspa?name=zfwang">王之枫</a>
                                        <font size="-2">
            [
                <font color="#336699">12/&#19977;&#26376;/26</font>

                            ]
            </font>

        </td></tr>
        <tr id="comment-body-382424"><td bgcolor="#ffffff">

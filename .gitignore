# 龙虾 AI 助手工作区 - Git 忽略文件

# 日志文件
logs/
*.log

# 缓存
.cache/
__pycache__/
*.pyc

# 临时文件
*.tmp
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# OpenClaw 状态文件（可选）
# .openclaw/workspace-state.json

# 敏感信息（如果有的话）
*.key
*.secret
.env.local

# 大型二进制文件
*.bin
*.exe

# 节点模块（如果有）
node_modules/

# 构建输出
dist/
build/
